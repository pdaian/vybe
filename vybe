class LiveStatus:
    """
    Multi-line terminal animation with reduced flicker.
    """

    def __init__(self, label: str = "Codex is thinking", mode: str = "radar") -> None:
        self.label = label
        self.mode = mode
        self._stop = threading.Event()
        self._pause = threading.Event()
        self._thread: Optional[threading.Thread] = None
        self._start_time = 0.0
        self._lock = threading.Lock()
        self._tick = 0
        self._rng = random.Random()
        self._last_lines: List[str] = []
        self._drawn_once = False
        self._spinner_frames = ["|", "/", "-", "\\"]
        self._radar_phase = [
            [self._rng.random() * math.tau for _x in range(RADAR_WIDTH)]
            for _y in range(RADAR_HEIGHT)
        ]
        self._radar_bias = [
            [self._rng.uniform(-0.9, 0.9) for _x in range(RADAR_WIDTH)]
            for _y in range(RADAR_HEIGHT)
        ]
        self._constellations = [
            (self._rng.randrange(RADAR_WIDTH), self._rng.randrange(RADAR_HEIGHT))
            for _ in range(5)
        ]

    def start(self) -> None:
        self._start_time = time.time()
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()

    def _move_up(self, n: int) -> None:
        if n > 0:
            sys.stdout.write(f"\033[{n}A")

    def _paint(self, lines: List[str]) -> None:
        if not self._drawn_once:
            sys.stdout.write("\n".join(lines))
            sys.stdout.write("\n")
            sys.stdout.flush()
            self._last_lines = lines[:]
            self._drawn_once = True
            return

        self._move_up(len(self._last_lines))
        max_lines = max(len(self._last_lines), len(lines))
        padded_new = lines + [""] * (max_lines - len(lines))
        padded_old = self._last_lines + [""] * (max_lines - len(self._last_lines))

        for i, (_old, new) in enumerate(zip(padded_old, padded_new)):
            sys.stdout.write("\r\033[2K")
            sys.stdout.write(new)
            if i < max_lines - 1:
                sys.stdout.write("\n")

        sys.stdout.flush()
        self._last_lines = lines[:]

    def _final_clear(self) -> None:
        if not self._drawn_once:
            return

        self._move_up(len(self._last_lines))
        for i in range(len(self._last_lines)):
            sys.stdout.write("\r\033[2K")
            if i < len(self._last_lines) - 1:
                sys.stdout.write("\n")
        if self._last_lines:
            self._move_up(len(self._last_lines) - 1)
            sys.stdout.write("\r")
        sys.stdout.flush()

        self._last_lines = []
        self._drawn_once = False

    def _render_lines(self) -> List[str]:
        elapsed = time.time() - self._start_time
        if not supports_ansi() or self.mode == "spinner":
            return self._render_spinner(elapsed)
        return self._render_radar(elapsed)

    def _render_spinner(self, elapsed: float) -> List[str]:
        frame = self._spinner_frames[self._tick % len(self._spinner_frames)]
        return [f"{DIM}{frame} {self.label}... {elapsed:5.1f}s{RESET}"]

    def _render_radar(self, elapsed: float) -> List[str]:
        width = RADAR_WIDTH
        height = RADAR_HEIGHT
        sweep_x = self._tick % width
        pulse_y = (self._tick // 2) % height
        t = float(self._tick)

        chars: List[List[str]] = []
        for y in range(height):
            row: List[str] = []
            for x in range(width):
                phase = self._radar_phase[y][x]
                bias = self._radar_bias[y][x]
                drift = math.sin(phase + t * 0.20 + x * 0.33)
                ripple = math.sin((x - y) * 0.48 - t * 0.16 + phase * 0.7)
                bloom = math.cos((x + y) * 0.35 + t * 0.11 + bias)
                signal = drift + 0.8 * ripple + 0.6 * bloom + bias * 0.4

                ch = " "
                if signal > 1.55:
                    ch = "✦"
                elif signal > 0.95:
                    ch = "*"
                elif signal > 0.40:
                    ch = "•"
                elif signal > -0.05:
                    ch = "·"
                elif signal > -0.60:
                    ch = "."

                if abs(x - sweep_x) == 0:
                    ch = "│"
                elif abs(x - sweep_x) == 1:
                    ch = "╎"
                elif abs(x - sweep_x) == 2 and ch == " ":
                    ch = "·"

                arc_y = int((height - 1) * (0.5 + 0.32 * math.sin(t * 0.14 + x * 0.24)))
                if y == arc_y and (x + self._tick) % 5 == 0:
                    ch = "─"
                if y == (pulse_y + (x // 6)) % height and (x + self._tick) % 9 == 0:
                    ch = "•"
                if ch in {"✦", "*", "•"} and (x + y + self._tick) % 23 == 0:
                    ch = art_noise_glyph(self._rng)
                row.append(ch)
            chars.append(row)

        for i, (base_x, base_y) in enumerate(self._constellations):
            cx = (base_x + self._tick * (i + 1)) % width
            cy = int((base_y + 1.5 * math.sin(t * 0.12 + i * 1.7)) % height)
            for dy, dx, mark in [(0, 0, "◉"), (0, 1, "•"), (1, 0, "•")]:
                yy = cy + dy
                xx = cx + dx
                if 0 <= yy < height and 0 <= xx < width:
                    chars[yy][xx] = mark

        body = []
        for y, row in enumerate(chars):
            rendered = []
            for x, ch in enumerate(row):
                seed = x * 11 + y * 17 + self._tick * 3
                if ch in {"◉", "✦"}:
                    rendered.append(c(ch, art_color(seed)))
                elif ch in {"•", "*", "+"} or ch in ART_BRIGHT_GLYPHS:
                    rendered.append(c(ch, art_color(seed + 1)))
                elif ch in {"│", "╎", "─"}:
                    rendered.append(c(ch, art_color(seed + 2)))
                elif ch in {"·", "."}:
                    if (x + y + self._tick) % 4 == 0:
                        rendered.append(c(ch, art_color(seed + 3, ART_COLORS[:-1])))
                    else:
                        rendered.append(c(ch, DIM))
                else:
                    rendered.append(ch)
            body.append("".join(rendered))

        status_a = f"model={CODEX_MODEL}"
        status_b = f"t={elapsed:5.1f}s"
        status_c = f"mode={CODEX_SANDBOX}"

        top = f"┌{'─' * width}┐"
        bottom = f"└{'─' * width}┘"
        title = f"{BOLD}{CYAN} {self.label}{RESET}"
        meta = f"{DIM}{status_a}  {status_b}  {status_c}{RESET}"

        rendered = [title, meta, top]
        for line in body:
            rendered.append("│" + line + "│")
        rendered.append(bottom)
        rendered.append(c(" scanning repo state / signal bloom / patch vectors ", DIM))
        return rendered

    def _run(self) -> None:
        while not self._stop.is_set():
            if self._pause.is_set():
                time.sleep(0.02)
                continue

            lines = self._render_lines()
            with self._lock:
                self._paint(lines)

            self._tick += 1
            time.sleep(RADAR_INTERVAL if self.mode == "radar" else SPINNER_INTERVAL)

        with self._lock:
            self._final_clear()

    def pause_for_output(self) -> None:
        self._pause.set()
        with self._lock:
            self._final_clear()

    def resume(self) -> None:
        self._pause.clear()

    def stop(self) -> None:
        self._stop.set()
        if self._thread:
            self._thread.join(timeout=1.0)


