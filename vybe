# CODEX EXECUTION
# =============================================================================

def extract_summary_from_stream(text: str) -> str:
    blocks = [b.strip() for b in re.split(r"\n\s*\n", text) if b.strip()]
    if not blocks:
        return "(No summary captured.)"

    for block in reversed(blocks):
        stripped = block.strip()
        if stripped.startswith("{") and stripped.endswith("}"):
            continue
        return stripped

    return blocks[-1]


def run_codex(
    support: CodexSupport,
    working_dir: Path,
    prompt_text: str,
) -> Tuple[str, str]:
    options = parse_prompt_options(prompt_text)
    if not options.prompt_text:
        raise CommandError("Prompt is empty after removing slash commands.")

    summary_file = (working_dir.parent / "last_message.txt").resolve()
    summary_file.unlink(missing_ok=True)
    cmd = build_codex_command(support, options, summary_file)

    banner("RUNNING CODEX")
    print("Command:")
    print(" ".join(shlex.quote(x) for x in cmd[:-1]))
    print("\nPrompt:")
    print(options.prompt_text)
    print("\nOutput:")
    print("-" * 88)

    proc = subprocess.Popen(
        cmd,
        cwd=str(working_dir),
        env=build_codex_env(),
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,
    )

    live = LiveStatus("Codex is thinking", mode="radar")
    live.start()

    out_lines: List[str] = []
    assert proc.stdout is not None
    rc = 0

    try:
        for line in proc.stdout:
            out_lines.append(line)
            if SHOW_FULL_CODEX_STREAM:
                live.pause_for_output()
                sys.stdout.write(line)
                sys.stdout.flush()
                live.resume()
        rc = proc.wait()
    finally:
        live.stop()

    print("-" * 88)

    combined = "".join(out_lines)
    if rc != 0:
        raise CommandError(f"Codex failed with exit code {rc}\n{combined}")

    if summary_file.exists():
        summary = summary_file.read_text(encoding="utf-8", errors="replace").strip()
    else:
        summary = extract_summary_from_stream(combined)

    if not summary:
        summary = "(No summary captured.)"

    return summary, combined


