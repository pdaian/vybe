def make_temp_snapshot(repo: Path) -> Tuple[Path, Path, Path]:
    repo = repo.resolve()
    temp_root = Path(tempfile.mkdtemp(prefix="codex-run-")).resolve()
    snapshot = (temp_root / "snapshot").resolve()
    working = (temp_root / "working").resolve()
    snapshot.mkdir(parents=True, exist_ok=True)

    archive_path = (temp_root / "repo.tar").resolve()
    with archive_path.open("wb") as f:
        proc = subprocess.run(
            ["git", "archive", "--format=tar", "HEAD"],
            cwd=str(repo),
            stdout=f,
            stderr=subprocess.PIPE,
        )
        if proc.returncode != 0:
            raise CommandError(f"git archive failed:\n{proc.stderr.decode()}")

    run_cmd(["tar", "-xf", str(archive_path), "-C", str(snapshot)])
    shutil.copytree(snapshot, working, dirs_exist_ok=False)
    init_temp_git_repo(working)
    return temp_root, snapshot, working


def cleanup_temp_dir(temp_root: Path) -> None:
    shutil.rmtree(temp_root, ignore_errors=True)


def init_temp_git_repo(working_dir: Path) -> None:
    git_env = build_temp_git_env()
    run_cmd(["git", "init"], cwd=working_dir, env=git_env)
    run_cmd(["git", "add", "-A"], cwd=working_dir, env=git_env)
    run_cmd(["git", "commit", "--allow-empty", "-m", "snapshot"], cwd=working_dir, env=git_env)


