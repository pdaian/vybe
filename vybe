def c(text: str, color: str) -> str:
    return f"{color}{text}{RESET}"


def art_color(seed: int, palette: Sequence[str] = ART_COLORS) -> str:
    return palette[seed % len(palette)]


def art_noise_glyph(rng: random.Random) -> str:
    roll = rng.random()
    if roll < 0.72:
        return rng.choice(ART_SPARK_GLYPHS)
    if roll < 0.88:
        return rng.choice(ART_ALNUM_GLYPHS)
    if roll < 0.97:
        return rng.choice(ART_SYMBOL_GLYPHS)
    return rng.choice(ART_EMOJI_GLYPHS)


def banner(title: str) -> None:
    line = "=" * 88
    print(f"\n{line}\n{title}\n{line}")


def info(text: str) -> None:
    print(c(text, CYAN))


def warn(text: str) -> None:
    print(c(text, YELLOW))


def err(text: str) -> None:
    print(c(text, RED))


def ok(text: str) -> None:
    print(c(text, GREEN))


def supports_ansi() -> bool:
    return sys.stdout.isatty() and os.environ.get("TERM", "") != "dumb"


def clear_display() -> None:
    if not supports_ansi():
        return
    sys.stdout.write("\033[H\033[2J")
    sys.stdout.flush()


def run_cmd(
    args: Sequence[str],
    *,
    cwd: Optional[Path] = None,
    env: Optional[Dict[str, str]] = None,
    check: bool = True,
    capture: bool = True,
    input_text: Optional[str] = None,
) -> subprocess.CompletedProcess:
    proc = subprocess.run(
        list(args),
        cwd=str(cwd) if cwd else None,
        env=env,
        text=True,
        capture_output=capture,
        input=input_text,
    )
    if check and proc.returncode != 0:
        cmd_str = " ".join(shlex.quote(x) for x in args)
        raise CommandError(
            f"Command failed ({proc.returncode}): {cmd_str}\n"
            f"STDOUT:\n{proc.stdout}\n"
            f"STDERR:\n{proc.stderr}"
        )
    return proc


def ensure_binary(name: str) -> None:
    if shutil.which(name) is None:
        raise SystemExit(f"Missing required binary in PATH: {name}")


def resolve_repo_root_from_cwd() -> Path:
    cwd = Path.cwd().resolve()
    proc = run_cmd(["git", "rev-parse", "--show-toplevel"], cwd=cwd)
    return Path(proc.stdout.strip()).resolve()


def get_repo_root() -> Path:
    return resolve_repo_root_from_cwd()


def get_current_branch(repo: Path) -> str:
    proc = run_cmd(["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=repo)
    branch = proc.stdout.strip()
    if branch == "HEAD":
        raise SystemExit("Detached HEAD is not supported.")
    return branch


def ensure_clean_repo(repo: Path) -> None:
    proc = run_cmd(["git", "status", "--porcelain"], cwd=repo)
    if proc.stdout.strip():
        raise SystemExit(
            "Working tree is not clean. Commit, stash, or discard local changes first."
        )


def git_remote_url(repo: Path, remote_name: str) -> str:
    proc = run_cmd(["git", "remote", "get-url", remote_name], cwd=repo)
    return proc.stdout.strip()


def has_remote(repo: Path, remote_name: str) -> bool:
    proc = run_cmd(["git", "remote"], cwd=repo)
    remotes = {line.strip() for line in proc.stdout.splitlines() if line.strip()}
    return remote_name in remotes


def tokenized_https_url(url: str, username: str, token: str) -> str:
    if not username or not token:
        return url
    if not url.startswith("https://"):
        raise SystemExit("Only HTTPS remotes are supported for embedded token auth.")
    rest = url[len("https://"):]
    return f"https://{username}:{token}@{rest}"


def resolve_git_remote_credentials() -> Tuple[str, str]:
    if GIT_REMOTE_USERNAME and GIT_REMOTE_TOKEN:
        return GIT_REMOTE_USERNAME, GIT_REMOTE_TOKEN

    if not GITHUB_PAT_FILE.is_file():
        return GIT_REMOTE_USERNAME, GIT_REMOTE_TOKEN

    lines = GITHUB_PAT_FILE.read_text(encoding="utf-8").splitlines()
    username = lines[0].strip() if len(lines) >= 1 else ""
    token = lines[1].strip() if len(lines) >= 2 else ""
    return username, token


