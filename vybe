def detect_codex_support() -> CodexSupport:
    proc = run_cmd([CODEX_BINARY, "exec", "--help"], check=False, capture=True)
    text = (proc.stdout or "") + "\n" + (proc.stderr or "")
    return CodexSupport(
        has_json="--json" in text,
        has_output_last_message="--output-last-message" in text,
        has_search="--search" in text,
    )


def build_codex_command(
    support: CodexSupport,
    options: PromptOptions,
    summary_file: Path,
) -> List[str]:
    codex_mode = get_codex_mode()
    cmd = [
        CODEX_BINARY,
        "exec", "--skip-git-repo-check",
        "--model", CODEX_MODEL,
        "--sandbox", CODEX_SANDBOX,
    ]

    if codex_mode == "fast":
        cmd += ["--enable", "fast_mode"]
    else:
        cmd += ["--disable", "fast_mode"]

    if CODEX_USE_JSON_IF_AVAILABLE and support.has_json:
        cmd.append("--json")

    if (CODEX_ENABLE_WEB_SEARCH or options.enable_search) and support.has_search:
        cmd.append("--search")

    if support.has_output_last_message:
        cmd += ["--output-last-message", str(summary_file)]

    full_prompt = (
        options.prompt_text.strip()
        + "\n\n"
        + build_prompt_suffix(plan_mode=options.plan_mode)
        + "\n"
    )
    cmd.append(full_prompt)
    return cmd


