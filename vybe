def main() -> int:
    ensure_binary("git")
    ensure_binary("tar")
    ensure_binary(CODEX_BINARY)

    support = detect_codex_support()
    codex_mode = get_codex_mode()
    repo = get_repo_root().resolve()
    invocation_cwd = Path.cwd().resolve()

    banner("CODEX LOOP")
    print(f"Script: {SCRIPT_PATH}")
    print(f"CWD:    {invocation_cwd}")
    print(f"Repo:   {repo}")
    print(f"Model:  {CODEX_MODEL}")
    print(f"Mode:   {codex_mode}")
    print(f"Remote: {GIT_REMOTE_NAME}")
    print(f"Commit: {COMMIT_MODE}")
    print(
        f"Codex support: json={support.has_json}, "
        f"output-last-message={support.has_output_last_message}, "
        f"search={support.has_search}"
    )
    print("\nType quit or exit to stop.")

    while True:
        user_prompt = idle_prompt_multiline("\ncodex> ", repo).strip()
        if user_prompt.lower() in {"quit", "exit"}:
            print("Bye.")
            return 0
        if not user_prompt:
            continue

        ensure_clean_repo(repo)

        temp_root: Optional[Path] = None
        try:
            temp_root, snapshot_dir, working_dir = make_temp_snapshot(repo)
            summary, _combined = run_codex(support, working_dir, user_prompt)
            changed_files = compute_changed_files(repo, snapshot_dir, working_dir)
            prompt_history = [user_prompt]
            summary_history = [summary]

            result = RunResult(
                prompt=user_prompt,
                summary=format_session_summary(summary_history, changed_files),
                changed_files=changed_files,
                temp_root=temp_root,
                snapshot_dir=snapshot_dir,
                working_dir=working_dir,
                prompt_history=prompt_history,
                summary_history=summary_history,
            )

            clear_display()
            print_summary(result)
            decision_loop(repo, support, result)

        except CommandError as e:
            banner("ERROR")
            err(str(e))
        except Exception as e:
            banner("UNEXPECTED ERROR")
            err(repr(e))
        finally:
            if temp_root is not None:
                cleanup_temp_dir(temp_root)


if __name__ == "__main__":
    raise SystemExit(main())
