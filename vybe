def get_codex_mode() -> str:
    raw = os.environ.get(CODEX_MODE_ENV_VAR, "fast").strip().lower()
    aliases = {
        "2x": "fast",
        "fast": "fast",
        "normal": "slow",
        "slow": "slow",
    }
    mode = aliases.get(raw)
    if mode is None:
        raise SystemExit(
            f"Invalid {CODEX_MODE_ENV_VAR}={raw!r}. Use fast, 2x, slow, or normal."
        )
    return mode


def parse_prompt_options(prompt_text: str) -> PromptOptions:
    lines = prompt_text.splitlines()
    idx = 0
    enable_search = False
    plan_mode = False

    while idx < len(lines):
        directive = lines[idx].strip().lower()
        if directive == "/search":
            enable_search = True
            idx += 1
            continue
        if directive == "/plan":
            plan_mode = True
            idx += 1
            continue
        break

    cleaned_prompt = "\n".join(lines[idx:]).strip()
    return PromptOptions(
        prompt_text=cleaned_prompt,
        enable_search=enable_search,
        plan_mode=plan_mode,
    )


def build_prompt_suffix(*, plan_mode: bool) -> str:
    suffix = textwrap.dedent(CODEX_EXTRA_SUFFIX).strip()
    if not plan_mode:
        return suffix

    lines = [line for line in suffix.splitlines() if line.strip() != PLAN_MODE_CODE_PROMPT]
    return "\n".join(lines).strip()


