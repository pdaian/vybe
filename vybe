# FILE DIFFING
# =============================================================================

def list_paths_recursive(root: Path) -> Dict[str, Path]:
    result: Dict[str, Path] = {}
    for p in root.rglob("*"):
        if p.is_dir() or p.is_file():
            rel = str(p.relative_to(root)).replace("\\", "/")
            result[rel] = p
    return result


def git_status_entries(working_dir: Path) -> List[Tuple[str, str]]:
    proc = run_cmd(
        ["git", "status", "--porcelain", "-z", "--untracked-files=all", "--no-renames"],
        cwd=working_dir,
    )
    entries: List[Tuple[str, str]] = []
    for raw in proc.stdout.split("\0"):
        if not raw:
            continue
        status = raw[:2]
        path = raw[3:].replace("\\", "/")
        if path:
            entries.append((status, path))
    return entries


def compute_changed_files(repo: Path, snapshot_dir: Path, working_dir: Path) -> List[ChangedFile]:
    old_map = list_paths_recursive(snapshot_dir)
    new_map = list_paths_recursive(working_dir)
    changed: List[ChangedFile] = []

    seen: set[str] = set()
    for status, rel in git_status_entries(working_dir):
        if rel in seen or should_ignore_path(repo, rel):
            continue
        seen.add(rel)
        if status == "??":
            changed.append(ChangedFile(rel, "A", None, new_map.get(rel)))
            continue
        if "D" in status:
            changed.append(ChangedFile(rel, "D", old_map.get(rel), None))
            continue
        if "A" in status and rel not in old_map:
            changed.append(ChangedFile(rel, "A", None, new_map.get(rel)))
            continue
        changed.append(ChangedFile(rel, "M", old_map.get(rel), new_map.get(rel)))

    return changed


def is_binary_file(path: Path) -> bool:
    try:
        data = path.read_bytes()[:8192]
    except Exception:
        return True
    return b"\x00" in data


def _safe_read_lines(path: Optional[Path]) -> List[str]:
    if path is None:
        return []
    if is_binary_file(path):
        return ["<binary file>\n"]
    return path.read_text(encoding="utf-8", errors="replace").splitlines(keepends=True)


def colorize_diff_line(line: str) -> str:
    if line.startswith("--- ") or line.startswith("+++ "):
        return c(line.rstrip("\n"), BOLD)
    if line.startswith("@@"):
        return c(line.rstrip("\n"), CYAN)
    if line.startswith("+") and not line.startswith("+++ "):
        return c(line.rstrip("\n"), GREEN)
    if line.startswith("-") and not line.startswith("--- "):
        return c(line.rstrip("\n"), RED)
    return line.rstrip("\n")


def render_diff(ch: ChangedFile) -> str:
    if (ch.old_abs and ch.old_abs.is_dir()) or (ch.new_abs and ch.new_abs.is_dir()):
        if ch.status == "A":
            return f"(directory added: {ch.path})"
        if ch.status == "D":
            return f"(directory removed: {ch.path})"
        return f"(path type changed: {ch.path})"

    old_lines = _safe_read_lines(ch.old_abs)
    new_lines = _safe_read_lines(ch.new_abs)

    diff = difflib.unified_diff(
        old_lines,
        new_lines,
        fromfile=f"a/{ch.path}",
        tofile=f"b/{ch.path}",
        lineterm="",
    )
    lines = list(diff)
    if not lines:
        return "(no textual diff available)"
    return "\n".join(colorize_diff_line(line) for line in lines)


def summarize_changed_files(changed_files: List[ChangedFile]) -> str:
    if not changed_files:
        return "Net diff: no file changes."

    counts = {"A": 0, "M": 0, "D": 0}
    for ch in changed_files:
        counts[ch.status] = counts.get(ch.status, 0) + 1

    parts: List[str] = []
    if counts["A"]:
        parts.append(f"{counts['A']} added")
    if counts["M"]:
        parts.append(f"{counts['M']} modified")
    if counts["D"]:
        parts.append(f"{counts['D']} deleted")

    return f"Net diff: {len(changed_files)} file(s) changed ({', '.join(parts)})."


def format_session_summary(summary_history: List[str], changed_files: List[ChangedFile]) -> str:
    latest = (summary_history[-1].strip() if summary_history else "") or "(No summary captured.)"
    net = summarize_changed_files(changed_files)

    if len(summary_history) <= 1:
        return f"{latest}\n\n{net}"

    return f"Session prompts: {len(summary_history)}\n\nLatest prompt summary:\n{latest}\n\n{net}"


