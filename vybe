def print_summary(result: RunResult) -> None:
    banner("SESSION SUMMARY")
    print(result.summary)

    banner("CHANGED FILES")
    if not result.changed_files:
        print("(No non-ignored file changes detected.)")
        return

    for idx, ch in enumerate(result.changed_files, start=1):
        label = {
            "A": c("A", GREEN),
            "M": c("M", YELLOW),
            "D": c("D", RED),
        }.get(ch.status, ch.status)

        path_display = ch.path
        if len(path_display) > MAX_FILE_LIST_WIDTH:
            path_display = "..." + path_display[-(MAX_FILE_LIST_WIDTH - 3):]

        print(f"{idx:>3}. [{label}] {path_display}")


def inspect_loop(result: RunResult, repo: Path) -> None:
    if not result.changed_files:
        warn("Nothing to inspect.")
        return

    while True:
        banner("INSPECT")
        for idx, ch in enumerate(result.changed_files, start=1):
            print(f"{idx:>3}. [{ch.status}] {ch.path}")

        choice = idle_prompt_line("\nFile number to inspect, or Enter to go back: ", repo).strip()
        if choice == "":
            return
        if not choice.isdigit():
            warn("Please enter a valid number.")
            continue

        n = int(choice)
        if not (1 <= n <= len(result.changed_files)):
            warn("Out of range.")
            continue

        ch = result.changed_files[n - 1]
        banner(f"DIFF: {ch.path}")
        print(render_diff(ch))
        idle_prompt_line("\nPress Enter to return to inspect menu... ", repo)


def extend_result(repo: Path, support: CodexSupport, result: RunResult) -> None:
    extra_prompt = idle_prompt_multiline("\nextend> ", repo).strip()
    if not extra_prompt:
        warn("Extend prompt was empty.")
        return

    summary, _combined = run_codex(support, result.working_dir, extra_prompt)
    result.prompt_history.append(extra_prompt)
    result.summary_history.append(summary)
    result.changed_files = compute_changed_files(repo, result.snapshot_dir, result.working_dir)
    result.prompt = "\n\n".join(result.prompt_history)
    result.summary = format_session_summary(result.summary_history, result.changed_files)

    clear_display()
    print_summary(result)


def decision_loop(repo: Path, support: CodexSupport, result: RunResult) -> None:
    while True:
        banner("DECISION")
        choice = idle_prompt_line("[a]pply / [r]eject / [i]nspect / e[x]tend: ", repo).strip().lower()

        if choice in {"i", "inspect"}:
            inspect_loop(result, repo)
            continue

        if choice in {"x", "extend"}:
            extend_result(repo, support, result)
            continue

        if choice in {"r", "reject"}:
            warn("Rejected. Discarding changes.")
            return

        if choice in {"a", "apply"}:
            if not result.changed_files:
                warn("No changes to apply.")
                return
            apply_result(repo, result)
            return

        warn("Please choose apply, reject, inspect, or extend.")


