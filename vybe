class IdleMatrixPanel:
    """
    Static matrix-style panel shown before input() starts.
    It stays visible while the user types, but does not animate.
    """

    def __init__(self, repo: Path) -> None:
        self.repo = repo
        self._rng = random.Random()
        self._last_line_count = 0
        self._enabled = supports_ansi()

    def _move_up(self, n: int) -> None:
        if n > 0:
            sys.stdout.write(f"\033[{n}A")

    def clear(self) -> None:
        if not self._enabled or self._last_line_count <= 0:
            return
        self._move_up(self._last_line_count)
        for i in range(self._last_line_count):
            sys.stdout.write("\r\033[2K")
            if i < self._last_line_count - 1:
                sys.stdout.write("\n")
        if self._last_line_count > 1:
            self._move_up(self._last_line_count - 1)
        sys.stdout.write("\r")
        sys.stdout.flush()
        self._last_line_count = 0

    def _render_lines(self) -> List[str]:
        width = 34
        height = 5
        scan = self._rng.randrange(width)

        body: List[str] = []
        for _y in range(height):
            row = []
            for x in range(width):
                ch = " "
                if x == scan:
                    ch = "│"
                elif x == (scan - 1) % width:
                    ch = "·"
                elif self._rng.random() < 0.05:
                    ch = art_noise_glyph(self._rng)
                row.append(ch)

            rendered = []
            for x, ch in enumerate(row):
                if ch == "│":
                    rendered.append(c(ch, art_color(scan + x)))
                elif ch in ART_BRIGHT_GLYPHS:
                    rendered.append(c(ch, art_color(scan * 3 + x)))
                elif ch in {".", "·"}:
                    if self._rng.random() < 0.35:
                        rendered.append(c(ch, art_color(scan * 5 + x, ART_COLORS[:-1])))
                    else:
                        rendered.append(c(ch, DIM))
                else:
                    rendered.append(ch)
            body.append("".join(rendered))

        repo_name = self.repo.name
        top = c(f"╔{'═' * width}╗", DIM)
        bottom = c(f"╚{'═' * width}╝", DIM)
        title = f"{BOLD}{GREEN} MATRIX IDLE {RESET}{DIM}repo={repo_name}{RESET}"
        footer = c(" waiting for prompt :: type task or quit ", DIM)

        return [title, top] + [f"║{line}║" for line in body] + [bottom, footer]

    def paint(self) -> None:
        if not self._enabled:
            return
        lines = self._render_lines()
        sys.stdout.write("\n".join(lines) + "\n")
        sys.stdout.flush()
        self._last_line_count = len(lines)


def idle_prompt_line(label: str, repo: Path) -> str:
    panel: Optional[IdleMatrixPanel] = None
    try:
        if supports_ansi():
            panel = IdleMatrixPanel(repo)
            panel.paint()
            print()
        return input(label)
    except (EOFError, KeyboardInterrupt):
        print()
        return "quit"
    finally:
        if panel is not None:
            panel.clear()


def idle_prompt_multiline(label: str, repo: Path) -> str:
    """
    Multiline prompt for Codex tasks.

    Submit rule:
    - 4 consecutive blank lines submits the prompt.
    - Regular Enter inserts a newline.
    """
    panel: Optional[IdleMatrixPanel] = None
    try:
        if supports_ansi():
            panel = IdleMatrixPanel(repo)
            panel.paint()
            print()

        print(label, end="", flush=True)
        print("(finish with 4 blank lines)", flush=True)

        lines: List[str] = []
        blank_streak = 0

        while True:
            try:
                line = input()
            except EOFError:
                if not lines:
                    print()
                    return "quit"
                break
            except KeyboardInterrupt:
                print()
                return "quit"

            if line == "":
                blank_streak += 1
            else:
                blank_streak = 0

            lines.append(line)

            if blank_streak >= 4:
                lines = lines[:-4]
                break

        while lines and lines[-1] == "":
            lines.pop()

        return "\n".join(lines)

    finally:
        if panel is not None:
            panel.clear()


