def path_matches_glob(relpath: str) -> bool:
    relpath = relpath.replace("\\", "/")
    for pat in IGNORE_GLOBS:
        if fnmatch.fnmatch(relpath, pat):
            return True
        parts = relpath.split("/")
        for i in range(len(parts)):
            sub = "/".join(parts[i:])
            if fnmatch.fnmatch(sub, pat):
                return True
    return False


def git_ignored_paths(repo: Path, relpaths: List[str]) -> set[str]:
    if not relpaths:
        return set()

    ignored: set[str] = set()
    chunk_size = 200
    for i in range(0, len(relpaths), chunk_size):
        chunk = relpaths[i:i + chunk_size]
        proc = subprocess.run(
            ["git", "check-ignore", "--stdin"],
            cwd=str(repo),
            input="\n".join(chunk),
            text=True,
            capture_output=True,
        )
        if proc.returncode in (0, 1):
            for line in proc.stdout.splitlines():
                line = line.strip()
                if line:
                    ignored.add(line)
    return ignored


def should_ignore_path(repo: Path, relpath: str, git_ignored: Optional[set[str]] = None) -> bool:
    relpath = relpath.replace("\\", "/")
    if path_matches_glob(relpath):
        return True
    if git_ignored is not None and relpath in git_ignored:
        return True
    return False


